{
  "name": "ayana",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:db:push": "node scripts/test-db-push.mjs",
    "test": "npm run test:db:push && vitest run",
    "test:watch": "npm run test:db:push && vitest",
    "test:coverage": "npm run test:db:push && vitest run --coverage",
    "test:e2e": "playwright test",
    "seed:production-demo": "node scripts/seed-production-demo.mjs",
    "verify": "npm run lint && npm run typecheck && npm run test:coverage && npm run test:e2e && npm run build"
  },
  "dependencies": {
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.7.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^0.546.0",
    "next": "16.2.4",
    "prisma": "^7.7.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.37.0",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.0.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
